# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Gmail IMAP Credentials
# NOTE: For Gmail, you must generate a 16-character App Password (not your primary password)
GMAIL_EMAIL=your_gmail_email@gmail.com
GMAIL_APP_PASSWORD=your_16_character_app_password

# ==========================================
# WhatsApp Configuration Options (Choose One)
# ==========================================

# Option A: CallMeBot API (Simplest, free, personal setup)
CALLMEBOT_API_KEY=your_callmebot_apikey
CALLMEBOT_PHONE=+919876543210 # Your phone number with country code

# Option B: Twilio Sandbox (Professional API, requires account setup)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=whatsapp:+14155238886 # Twilio WhatsApp sandbox sender
TWILIO_TO_NUMBER=whatsapp:+919876543210 # Recipient WhatsApp number with country code
